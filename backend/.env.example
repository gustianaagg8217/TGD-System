# Application
APP_NAME=TGd System
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# API
API_V1_STR=/api/v1
API_HOST=0.0.0.0
API_PORT=8000

# Database - Using SQLite for Phase 1 development
DATABASE_URL=sqlite:///./tgd_system_phase1.db
# To switch to PostgreSQL, comment above and uncomment below:
# DATABASE_URL=postgresql://tgd_user:tgd_password@localhost:5432/tgd_system
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_EXPIRE=3600

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# JWT
JWT_SUBJECT=access

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# File Upload
MAX_FILE_SIZE=52428800  # 50MB
ALLOWED_FILE_EXTENSIONS=["pdf", "jpg", "jpeg", "png", "doc", "docx", "xls", "xlsx"]

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Telegram (Optional - for alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Optional - for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=

# Feature Flags
ENABLE_WEBSOCKET=false
ENABLE_SENSOR_SIMULATION=true
ENABLE_EMAIL_NOTIFICATIONS=false
