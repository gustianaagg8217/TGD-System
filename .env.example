# =============================================================================
# TGd System - Environment Configuration Template
# Copy this file to .env and update values for your environment
# =============================================================================

# ===== Application Settings =====
APP_NAME=TGd System
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ===== Database Configuration =====
DB_USER=tgd_user
DB_PASSWORD=tgd_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tgd_system
DATABASE_URL=postgresql://tgd_user:tgd_password@localhost:5432/tgd_system

# For production, use PostgreSQL. For development, can use SQLite
# DATABASE_URL=sqlite:///./tgd_system.db

# ===== Redis Cache =====
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_PASSWORD=redis_password

# ===== API Settings =====
API_HOST=0.0.0.0
API_PORT=8000
API_V1_STR=/api/v1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ===== Security =====
# IMPORTANT: Change SECRET_KEY in production!
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ===== MQTT Adapter Settings =====
MQTT_ENABLED=true
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=tgd-system

# ===== Modbus Adapter Settings =====
MODBUS_ENABLED=true
MODBUS_HOST=localhost
MODBUS_PORT=502
MODBUS_SLAVE_ID=1
MODBUS_POLL_INTERVAL=5.0

# ===== Frontend Settings =====
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# ===== Email Settings (Optional) =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tgdsystem.com

# ===== Telegram Bot (Optional) =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Feature Flags =====
ENABLE_MQTT_ADAPTER=true
ENABLE_MODBUS_ADAPTER=true
ENABLE_ML_PREDICTIONS=true
ENABLE_HISTORICAL_DATA=true
